# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database ─────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/khelogully?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Add your Railway frontend URL and Flutter Web URL here
CORS_ORIGINS=https://your-railway-app.up.railway.app,http://localhost:3000,http://localhost:5173

# ── Encryption (optional but recommended) ─────────────────────────────────
# Must be exactly 64 hex chars
ENCRYPTION_KEY=replace_with_64_char_hex_string

# ── Sentry (optional) ──────────────────────────────────────────────────────
SENTRY_DSN=
